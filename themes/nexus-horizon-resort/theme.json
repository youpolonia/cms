{
    "name": "Nexus Horizon",
    "description": "Futuristic urban resort with smart luxury and immersive experiences",
    "version": "1.0.0",
    "author": "AI Theme Builder",
    "supports": {
        "theme-builder": true,
        "custom-header": true,
        "custom-footer": true,
        "custom-colors": true
    },
    "options": {
        "show_header": true,
        "show_footer": true,
        "body_background": "#0a0c14",
        "preload_fonts": true
    },
    "colors": {
        "primary": "#00ff9d",
        "secondary": "#ff00c8",
        "accent": "#00d9ff",
        "background": "#0a0c14",
        "surface": "#141826",
        "text": "#e6f1ff",
        "text_muted": "#8a9bb8",
        "border": "#2a3042",
        "success": "#00ff9d",
        "warning": "#ffb800",
        "error": "#ff3860"
    },
    "typography": {
        "fontFamily": "Inter",
        "headingFont": "Inter",
        "baseFontSize": "16",
        "lineHeight": "1.6",
        "fontWeight": "400",
        "headingWeight": "700"
    },
    "buttons": {
        "borderRadius": "2",
        "paddingX": "36",
        "paddingY": "16",
        "fontWeight": "600",
        "uppercase": true,
        "shadow": true
    },
    "layout": {
        "containerWidth": "1400",
        "sectionSpacing": "140",
        "borderRadius": "12"
    },
    "homepage_sections": [
        {
            "id": "hero",
            "label": "Hero",
            "icon": "fas fa-star"
        },
        {
            "id": "smartrooms",
            "label": "Smart Rooms",
            "icon": "fas fa-brain"
        },
        {
            "id": "artexhibitions",
            "label": "Art & Exhibitions",
            "icon": "fas fa-palette"
        },
        {
            "id": "rooftop",
            "label": "Rooftop Experience",
            "icon": "fas fa-water"
        },
        {
            "id": "coworking",
            "label": "Co-Working Space",
            "icon": "fas fa-laptop"
        },
        {
            "id": "cta",
            "label": "Call to Action",
            "icon": "fas fa-bullhorn"
        }
    ],
    "thumbnail": "thumbnail.svg"
}
{
    "name": "Sentinel Core",
    "description": "AI-powered endpoint protection platform with zero-day prevention",
    "version": "1.0.0",
    "author": "AI Theme Builder",
    "supports": {
        "theme-builder": true,
        "custom-header": true,
        "custom-footer": true,
        "custom-colors": true
    },
    "options": {
        "show_header": true,
        "show_footer": true,
        "body_background": "#0a0a0f",
        "preload_fonts": true
    },
    "colors": {
        "primary": "#c2188f",
        "secondary": "#0f9d58",
        "accent": "#00e5ff",
        "background": "#0a0a0f",
        "surface": "#151522",
        "text": "#f0f0ff",
        "text_muted": "#a0a0c0",
        "border": "#2a2a3a",
        "success": "#0f9d58",
        "warning": "#f4b400",
        "error": "#ea4335"
    },
    "typography": {
        "fontFamily": "Inter",
        "headingFont": "Inter",
        "baseFontSize": "16",
        "lineHeight": "1.6",
        "fontWeight": "400",
        "headingWeight": "700"
    },
    "buttons": {
        "borderRadius": "2",
        "paddingX": "36",
        "paddingY": "16",
        "fontWeight": "600",
        "uppercase": true,
        "shadow": true
    },
    "layout": {
        "containerWidth": "1280",
        "sectionSpacing": "140",
        "borderRadius": "4"
    },
    "homepage_sections": [
        {
            "id": "hero",
            "label": "Hero",
            "icon": "fas fa-star"
        },
        {
            "id": "stats",
            "label": "Stats \/ Numbers",
            "icon": "fas fa-chart-bar"
        },
        {
            "id": "testimonials",
            "label": "Testimonials",
            "icon": "fas fa-quote-right"
        },
        {
            "id": "cta",
            "label": "Call to Action",
            "icon": "fas fa-bullhorn"
        },
        {
            "id": "features",
            "label": "Features",
            "icon": "✨"
        },
        {
            "id": "clients",
            "label": "Clients \/ Logos",
            "icon": "🏢"
        }
    ],
    "thumbnail": "thumbnail.svg"
}
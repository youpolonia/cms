{
    "name": "Synapse Nexus",
    "description": "A futuristic devtools theme for modern team communication platforms",
    "version": "1.0.0",
    "author": "AI Theme Builder",
    "supports": {
        "theme-builder": true,
        "custom-header": true,
        "custom-footer": true,
        "custom-colors": true
    },
    "options": {
        "show_header": true,
        "show_footer": true,
        "body_background": "#0a0e14",
        "preload_fonts": true
    },
    "colors": {
        "primary": "#d45a1e",
        "secondary": "#2a8bb8",
        "accent": "#00d4ff",
        "background": "#0a0e14",
        "surface": "#1a1f2a",
        "text": "#e6e9f0",
        "text_muted": "#a0a8c0",
        "border": "#2d3548",
        "success": "#10b981",
        "warning": "#f59e0b",
        "error": "#ef4444"
    },
    "typography": {
        "fontFamily": "Source Serif 4",
        "headingFont": "Archivo Narrow",
        "baseFontSize": "16",
        "lineHeight": "1.7",
        "fontWeight": "400",
        "headingWeight": "700"
    },
    "buttons": {
        "borderRadius": "4",
        "paddingX": "32",
        "paddingY": "14",
        "fontWeight": "600",
        "uppercase": true,
        "shadow": true
    },
    "layout": {
        "containerWidth": "1200",
        "sectionSpacing": "120",
        "borderRadius": "8"
    },
    "homepage_sections": [
        {
            "id": "hero",
            "label": "Hero",
            "icon": "fas fa-star"
        },
        {
            "id": "stats",
            "label": "Stats \/ Numbers",
            "icon": "fas fa-chart-bar"
        },
        {
            "id": "testimonials",
            "label": "Testimonials",
            "icon": "fas fa-quote-right"
        },
        {
            "id": "cta",
            "label": "Call to Action",
            "icon": "fas fa-bullhorn"
        },
        {
            "id": "features",
            "label": "Features",
            "icon": "✨"
        }
    ],
    "thumbnail": "thumbnail.svg"
}
{
    "name": "LinguaSphere Academy",
    "description": "Premium language immersion through conversation-first methodology and cultural exchange",
    "version": "1.0.0",
    "author": "AI Theme Builder",
    "supports": {
        "theme-builder": true,
        "custom-header": true,
        "custom-footer": true,
        "custom-colors": true
    },
    "options": {
        "show_header": true,
        "show_footer": true,
        "body_background": "#0a0f1a",
        "preload_fonts": true
    },
    "colors": {
        "primary": "#2a7de1",
        "secondary": "#d4a03a",
        "accent": "#3db8a6",
        "background": "#0a0f1a",
        "surface": "#131b2d",
        "text": "#e8f1ff",
        "text_muted": "#a0b4d6",
        "border": "#2a3650",
        "success": "#2d9d78",
        "warning": "#e6b450",
        "error": "#e65c5c"
    },
    "typography": {
        "fontFamily": "Inter",
        "headingFont": "Inter",
        "baseFontSize": "18",
        "lineHeight": "1.8",
        "fontWeight": "400",
        "headingWeight": "600"
    },
    "buttons": {
        "borderRadius": "6",
        "paddingX": "36",
        "paddingY": "16",
        "fontWeight": "600",
        "uppercase": true,
        "shadow": true
    },
    "layout": {
        "containerWidth": "1280",
        "sectionSpacing": "140",
        "borderRadius": "12"
    },
    "homepage_sections": [
        {
            "id": "hero",
            "label": "Hero",
            "icon": "fas fa-star"
        },
        {
            "id": "testimonials",
            "label": "Testimonials",
            "icon": "fas fa-quote-right"
        },
        {
            "id": "pricing",
            "label": "Pricing Preview",
            "icon": "fas fa-tags"
        },
        {
            "id": "faq",
            "label": "FAQ Preview",
            "icon": "fas fa-question-circle"
        },
        {
            "id": "cta",
            "label": "Call to Action",
            "icon": "fas fa-bullhorn"
        },
        {
            "id": "features",
            "label": "Features",
            "icon": "✨"
        }
    ],
    "thumbnail": "thumbnail.svg"
}